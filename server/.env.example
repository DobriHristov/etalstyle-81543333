# ===== Gmail SMTP (FREE - 500 emails/day) =====
# 1. Go to: https://myaccount.google.com/security
# 2. Enable "2-Step Verification"
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Generate "App password" (16 characters, no spaces)
# 5. Paste it below as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=youremail@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx

# Where inquiries will be delivered
MAIL_TO=youremail@gmail.com
MAIL_FROM_NAME=Etalstyle Website

# Server config
PORT=3001
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,https://etalstyle.lovable.app
